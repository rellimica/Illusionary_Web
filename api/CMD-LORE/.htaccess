# GENESIS_TECH // DATA_INTEGRITY_PROTECTION
# STATUS: RESTRICTED // LORE_LATTICE_LOCKED

# Prevent direct web access to lore JSON files.
# PHP scripts can still read these files locally.

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
